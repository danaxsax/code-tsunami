# Claude / Anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-haiku-latest

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_AGENT_ID=agent_5601ktgk8z39f7nbxt0hshsc8jpj
VITE_ELEVENLABS_AGENT_ID=agent_5601ktgk8z39f7nbxt0hshsc8jpj

# Optional per-cluster voices. These are used before country voices.
